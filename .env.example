# Copy to .env and fill in. Never commit .env.

# Data stores (compose dev defaults; host ports 5433/6380 avoid local clashes)
# DATABASE_URL is the superuser connection used by migrations, seed, and tests.
DATABASE_URL=postgresql+asyncpg://helpdeck:helpdeck@localhost:5433/helpdeck
# APP_DATABASE_URL is the restricted role the app serves requests as (RLS enforced).
# The role's login/password is provisioned OUTSIDE Alembic (dev: infra/init/01-app-role.sql;
# prod: deployment secret management) — the migration only grants privileges and sets RLS.
APP_DATABASE_URL=postgresql+asyncpg://helpdeck_app:helpdeck_app@localhost:5433/helpdeck
REDIS_URL=redis://localhost:6380/0

# Raw source storage (local filesystem in dev; object store in prod)
STORAGE_DIR=./storage

# Dev-only internal routes (e.g. POST /internal/search). Never enable in prod.
ENABLE_INTERNAL_ROUTES=false

# Agent guardrails + response cache
# Escalate a grounded answer only when the judge is quite unsure. 0.4 suits local
# OSS judge models (they under-score correct terse answers); raise toward 0.7 with
# a stronger hosted judge. Out-of-KB questions escalate regardless of this value.
FAITHFULNESS_THRESHOLD=0.4
AGENT_RETRIEVAL_TOP_N=8
RESPONSE_CACHE_TTL_SECONDS=3600

# Auth cookies (set COOKIE_SECURE=true behind HTTPS in prod)
COOKIE_SECURE=false
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Auth
JWT_SECRET=change-me-generate-a-long-random-string

# LLM + embeddings — default to a FREE, local, open-source stack served by Ollama
# (see infra/docker-compose.yml). No API keys required. Start it with:
#   docker compose -f infra/docker-compose.yml up -d ollama ollama-pull
# The gateway auto-selects: hosted provider (if a key below is set) -> Ollama
# (if reachable) -> deterministic offline stubs (so the app always runs).
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=ollama/nomic-embed-text
# EMBEDDING_DIMS must match EMBEDDING_MODEL's output width and the DB column
# (nomic-embed-text=768; text-embedding-3-small=1536 — changing it needs a migration).
EMBEDDING_DIMS=768
# Cheap route (routing/chitchat) stays small; the strong route (grounded answer
# + faithfulness judge) uses qwen2.5:7b (~4.7GB) for better answers and fewer
# false escalations. On low-RAM/CPU-only boxes, set LLM_STRONG_MODEL back to
# ollama_chat/llama3.2:3b (lighter, but escalates more).
LLM_CHEAP_MODEL=ollama_chat/llama3.2:3b
LLM_STRONG_MODEL=ollama_chat/qwen2.5:7b
RERANKER=none

# To use a hosted provider instead of Ollama, set a key AND matching models, e.g.:
#   ANTHROPIC_API_KEY=...   LLM_CHEAP_MODEL=claude-haiku-4-5-20251001  LLM_STRONG_MODEL=claude-sonnet-5
#   OPENAI_API_KEY=...      EMBEDDING_MODEL=text-embedding-3-small     EMBEDDING_DIMS=1536
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Required only when RERANKER=cohere
COHERE_API_KEY=

# Observability (Langfuse; optional in dev — tracing no-ops if unset)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Dashboard base URL — used to build member invite links
WEB_BASE_URL=http://localhost:3000

# Optional Slack-compatible webhook for quality regression alerts (6.5)
ALERT_WEBHOOK_URL=

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
