# Copy to .env and fill in. Never commit .env.

# Data stores (compose dev defaults; host ports 5433/6380 avoid local clashes)
# DATABASE_URL is the superuser connection used by migrations, seed, and tests.
DATABASE_URL=postgresql+asyncpg://helpdeck:helpdeck@localhost:5433/helpdeck
# APP_DATABASE_URL is the restricted role the app serves requests as (RLS enforced).
APP_DATABASE_URL=postgresql+asyncpg://helpdeck_app:helpdeck_app@localhost:5433/helpdeck
REDIS_URL=redis://localhost:6380/0

# Raw source storage (local filesystem in dev; object store in prod)
STORAGE_DIR=./storage

# Dev-only internal routes (e.g. POST /internal/search). Never enable in prod.
ENABLE_INTERNAL_ROUTES=false

# Agent guardrails + response cache
FAITHFULNESS_THRESHOLD=0.7
AGENT_RETRIEVAL_TOP_N=8
RESPONSE_CACHE_TTL_SECONDS=3600

# Auth cookies (set COOKIE_SECURE=true behind HTTPS in prod)
COOKIE_SECURE=false
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Auth
JWT_SECRET=change-me-generate-a-long-random-string

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LLM_CHEAP_MODEL=claude-haiku-4-5-20251001
LLM_STRONG_MODEL=claude-sonnet-5
RERANKER=none
# Required only when RERANKER=cohere
COHERE_API_KEY=

# Observability (Langfuse; optional in dev — tracing no-ops if unset)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
